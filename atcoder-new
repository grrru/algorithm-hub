#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $0 <contest> <problem>"
  echo "Example: $0 abc350 a"
}

if [ "$#" -ne 2 ]; then
  usage
  exit 1
fi

contest="$1"
problem="$2"
dir="atcoder/${contest}/${problem}"
url="https://atcoder.jp/contests/${contest}/tasks/${contest}_${problem}"
title="$(printf '%s %s' "$contest" "$problem" | tr '[:lower:]' '[:upper:]')"

mkdir -p "$dir"

if [ ! -f "${dir}/README.md" ]; then
  cat >"${dir}/README.md" <<EOF
# ${title}

- Problem: ${url}
- Status: TODO
EOF
fi

file="${dir}/main.go"
if [ ! -f "$file" ]; then
  cat >"$file" <<'EOF'
package main

func main() {
}
EOF
fi

echo "$dir"
echo "$url"
