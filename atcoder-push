#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -gt 1 ]; then
  echo "Usage: $0 [commit-message]" >&2
  exit 1
fi

detect_language() {
  case "$1" in
  *.go) echo "go" ;;
  *.cpp | *.cc | *.cxx) echo "cpp" ;;
  *.java) echo "java" ;;
  *) echo "" ;;
  esac
}

format_language() {
  case "$1" in
  go) echo "Go" ;;
  cpp) echo "C++" ;;
  java) echo "Java" ;;
  *) echo "$1" ;;
  esac
}

detect_problem() {
  local paths contests problems contest problem

  paths="$(git diff --name-only --cached -- atcoder)"
  contests="$(printf '%s\n' "$paths" | awk -F/ 'NF >= 3 {print $2}' | sort -u)"
  problems="$(printf '%s\n' "$paths" | awk -F/ 'NF >= 3 {print $3}' | sort -u)"

  if [ "$(printf '%s\n' "$contests" | sed '/^$/d' | wc -l | tr -d ' ')" -ne 1 ] ||
    [ "$(printf '%s\n' "$problems" | sed '/^$/d' | wc -l | tr -d ' ')" -ne 1 ]; then
    return
  fi

  contest="$(printf '%s\n' "$contests" | sed '/^$/d')"
  problem="$(printf '%s\n' "$problems" | sed '/^$/d')"
  echo "$contest/$problem"
}

mark_solved() {
  local problem_dir readme

  problem_dir="$1"
  readme="atcoder/${problem_dir}/README.md"

  if [ -f "$readme" ]; then
    sed -i.bak 's/^- Status: .*/- Status: Solved/' "$readme"
    rm -f "${readme}.bak"
  fi
}

default_message() {
  local paths langs contest problem lang path detected problem_dir

  problem_dir="$1"
  contest="${problem_dir%%/*}"
  problem="${problem_dir#*/}"
  paths="$(git diff --cached --name-only -- "atcoder/${problem_dir}")"
  langs=""

  while IFS= read -r path; do
    detected="$(detect_language "$path")"
    if [ -n "$detected" ]; then
      langs="${langs}${detected}"$'\n'
    fi
  done <<EOF
$paths
EOF

  lang="$(printf '%s\n' "$langs" | sed '/^$/d' | sort -u)"

  if [ "$(printf '%s\n' "$lang" | sed '/^$/d' | wc -l | tr -d ' ')" -ne 1 ]; then
    echo "Update AtCoder solutions"
    return
  fi

  lang="$(printf '%s\n' "$lang" | sed '/^$/d')"
  echo "Submit AtCoder $(printf '%s' "$contest" | tr '[:lower:]' '[:upper:]') $(printf '%s' "$problem" | tr '[:lower:]' '[:upper:]') solution in $(format_language "$lang")"
}

git add atcoder README.md

if git diff --cached --quiet; then
  echo "No changes to commit."
  exit 0
fi

problem_dir="$(detect_problem || true)"
if [ -n "$problem_dir" ]; then
  mark_solved "$problem_dir"
  git add "atcoder/${problem_dir}/README.md"
fi

message="${1:-Update AtCoder solutions}"
if [ "$#" -eq 0 ] && [ -n "$problem_dir" ]; then
  message="$(default_message "$problem_dir")"
fi

git commit -m "$message"
git push
